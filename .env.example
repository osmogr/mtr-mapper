# Copy this file to .env and adjust values before running `docker compose up`.

# --- Postgres ---
POSTGRES_USER=mtrmapper
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mtrmapper
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Assembled from the above by default; override directly if you need something custom.
DATABASE_URL=postgresql+asyncpg://mtrmapper:change-me@db:5432/mtrmapper

# --- Admin auth ---
# Shared admin password used to log into the /admin section.
ADMIN_PASSWORD=change-me-too
# Random secret used to sign the admin session cookie. Rotate this to invalidate all sessions.
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string
ADMIN_SESSION_TTL_SECONDS=28800

# --- Prober <-> backend auth ---
# Shared bearer token the prober container uses to call the backend's /api/prober/* endpoints.
PROBER_API_TOKEN=change-me-prober-token

# --- Prober scheduling / mtr tuning ---
PROBER_CONCURRENCY=20
PROBER_MIN_CYCLE_SECONDS=30
PROBER_TARGET_REFRESH_SECONDS=30
PROBER_RUN_TIMEOUT_SECONDS=60
MTR_PROBE_COUNT=5
MTR_PROBE_INTERVAL=1
MTR_TIMEOUT_SECONDS=1
MTR_MAX_HOPS=30
MTR_GRACETIME=5

# --- Backend retention / recompute tuning ---
TRACE_RETENTION_HOURS=48
RETENTION_SWEEP_INTERVAL_SECONDS=900
TREE_RECOMPUTE_INTERVAL_SECONDS=2
LOSS_WARN_THRESHOLD=2
LOSS_CRITICAL_THRESHOLD=20
TARGET_LIST_DEFAULT_FETCH_INTERVAL_SECONDS=3600

# --- ASN lookup (Team Cymru DNS whois) for public hop IPs ---
ASN_LOOKUP_ENABLED=true
ASN_LOOKUP_TIMEOUT_SECONDS=2
ASN_CACHE_TTL_HOURS=24

# --- Path history fade (stale/rerouted hops stay visible, dimming out) ---
PATH_FADE_HOURS=24

# --- Networking ---
BACKEND_URL=http://backend:8000
CORS_ALLOWED_ORIGINS=http://localhost:8080
FRONTEND_PORT=8080
BACKEND_PORT=8000
